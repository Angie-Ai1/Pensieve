# n8n 加密金鑰（必填）
# 用途：加密 n8n 內所有 credentials（API Key 等）
# 產生方式：openssl rand -hex 32
# 注意：此金鑰一旦用於正式資料，不可更換，否則既有 credentials 會失效需重新設定
N8N_ENCRYPTION_KEY=

# Volume 路徑（必填，本機絕對路徑，需設定為 Docker Desktop File sharing 允許清單）
# Chrome 瀏覽器 History 資料庫所在目錄（唯讀掛載）
# Windows 範例：C:/Users/<你的使用者名稱>/AppData/Local/Google/Chrome/User Data/Default
CHROME_HISTORY_PATH=

# Edge 瀏覽器 History 資料庫所在目錄（唯讀掛載）
# Windows 範例：C:/Users/<你的使用者名稱>/AppData/Local/Microsoft/Edge/User Data/Default
EDGE_HISTORY_PATH=

# Obsidian vault 路徑（讀寫掛載，每日彙整報告將寫入此處）
OBSIDIAN_VAULT_PATH=
